#include <iostream>
using namespace std;

int main() {
    float lecturaAnterior, lecturaActual, consumoTotal;
    float precioKW = 0, costoBase, ajuste = 0, totalFinal, consumoPorHabitante;
    int tipoVivienda, habitantes, altoConsumo, deudaAnterior;
    string mensaje;

    cout << "Lectura anterior: ";
    cin >> lecturaAnterior;
    cout << "Lectura actual: ";
    cin >> lecturaActual;
    cout << "Tipo de vivienda (1=Normal, 2=Social): ";
    cin >> tipoVivienda;
    cout << "Numero de habitantes: ";
    cin >> habitantes;
    cout << "Tiene artefactos de alto consumo? (1=Si, 0=No): ";
    cin >> altoConsumo;
    cout << "Tiene deuda anterior? (1=Si, 0=No): ";
    cin >> deudaAnterior;
    if (lecturaActual < lecturaAnterior) {
        cout << "Error: la lectura actual no puede ser menor que la anterior." << endl;
        return 0;
    }

    if (habitantes <= 0) {
        cout << "Error: el numero de habitantes debe ser mayor que 0." << endl;
        return 0;
    }
    consumoTotal = lecturaActual - lecturaAnterior;
    if (consumoTotal <= 100) {
        precioKW = 0.10;
    } else if (consumoTotal <= 200) {
        precioKW = 0.15;
    } else {
        precioKW = 0.20;
    }
    costoBase = consumoTotal * precioKW;
    if (deudaAnterior == 1) {
        ajuste = ajuste + (costoBase * 0.10);
    }
    if (tipoVivienda == 2 && consumoTotal <= 80) {
        ajuste = ajuste - (costoBase * 0.15);
    }
    totalFinal = costoBase + ajuste;
    consumoPorHabitante = consumoTotal / habitantes;
    if (altoConsumo == 1 && consumoTotal > 250) {
        mensaje = "Riesgo de sobrefacturacion";
    } else if (consumoPorHabitante > 60) {
        mensaje = "Alerta de consumo excesivo";
    } else {
        mensaje = "Consumo dentro de lo normal";
    }
    cout << "----- FACTURA ELECTRICA -----" << endl;
    cout << "Consumo total: " << consumoTotal << " kW" << endl;
    cout << "Costo base: $" << costoBase << endl;

    if (ajuste > 0) {
        cout << "Recargo: $" << ajuste << endl;
    } else if (ajuste < 0) {
        cout << "Subsidio: $" << ajuste << endl;
    } else {
        cout << "Subsidio o recargo: $0" << endl;
    }

    cout << "Total final: $" << totalFinal << endl;
    cout << "Mensaje preventivo: " << mensaje << endl;

    return 0;
}
