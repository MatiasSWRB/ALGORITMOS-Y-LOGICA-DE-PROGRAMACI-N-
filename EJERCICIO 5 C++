#include <iostream>
using namespace std;

int main() {
    int saldo, monto;
    int b20, b10, b5, b1;
    int u20, u10, u5, u1;
    int efectivo, restante;
    cout << "Saldo del usuario: ";
    cin >> saldo;
    cout << "Billetes de 20, 10, 5 y 1: "<<endl;
    cin >> b20 >> b10 >> b5 >> b1;
    cout << "Monto a retirar: ";
    cin >> monto;
    efectivo = b20*20 + b10*10 + b5*5 + b1;
  if (monto <= 0 || monto > saldo || monto > efectivo) {
        cout << "Error: operacion no valida." << endl;
        return 0;}
    restante = monto;
    u20 = min(restante / 20, b20);
    restante -= u20 * 20;
    u10 = min(restante / 10, b10);
    restante -= u10 * 10;
    u5 = min(restante / 5, b5);
    restante -= u5 * 5;
    u1 = min(restante, b1);
    restante -= u1;

    switch(restante) {
    case 0:
    cout << "Retiro exitoso";
    cout << " 20: " << u20 << " | 10: " << u10
    << " | 5: " << u5 << " | 1: " << u1 << endl;
    cout << "Saldo restante: " << saldo - monto << endl;
    cout << "Efectivo cajero: " << efectivo - monto << endl;
    break;
    default:
    cout << "\nNo se puede entregar el monto exacto." << endl;
    }
    return 0;
}




