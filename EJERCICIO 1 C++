if(Traecred==0){
    Estado="No puede ingresar";
    Motivo="No trae credencial";
    Prioridad="Alta";
}else if(Pertenece==0){
    Estado="No puede ingresar";
    Motivo="No Pertenece al curso y/o horario";
    Prioridad="Alta" ;
}else if(Numerof>=5){
    Estado="No puede ingresar";
    Motivo="Numero de faltas exedido";
