#include <iostream>
using namespace std;
int main(){
//Declaro variables
string Nombre,Horall,Estado,Motivo,Prioridad;
int Minutost, Numerof, Traecred, Pertenece;
//Pedir datos
cout<<"Nombre del estudiante: ";
cin>>Nombre;
